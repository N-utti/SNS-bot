# 백엔드 설정 (docker-compose 는 자체 환경변수로 덮어쓰므로 로컬 직접 실행용)
DATABASE_URL=postgres://sns:sns@localhost:5432/sns
APP_ENV=dev

# Notion 영구 자동 리포터 (매일 18:03). 비우면 스케줄 잡 미등록.
# notion.so/my-integrations 에서 internal integration 생성 → 토큰 붙여넣고
# 데일리 스크럼/리포트 DB(및 허브)를 그 integration 과 공유해야 함.
NOTION_TOKEN=

# M1 에서 추가 예정:
# FERNET_KEY=            # sns_accounts 자격증명 암호화 키 (base64, 32바이트)
# THREADS_APP_ID=
# THREADS_APP_SECRET=
# NAVER_CLIENT_ID=
# NAVER_CLIENT_SECRET=
